{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "white": "#f7f7f7",
    "black": "#111111",
    "mint": "#b3ffde",
    "blue": "#93d0ff",
    "amber": "#ffe093",
    "green": "#81ff91",
    "yellow": "#ffd479",
    "violet": "#c9b3ff",
    "red": "#ff3030",
    "grey": "#7c8595"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:white",
          "template": "┌"
        },
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:mint",
          "template": " 󰯉 {{ .Model.DisplayName }}"
        },
        {
          "type": "git",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:amber",
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": "<p:white> · </>{{ if .UpstreamURL }}{{ url .UpstreamIcon .UpstreamURL }} {{ end }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if or .Working.Changed .Staging.Changed }} <p:yellow></>{{ end }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:mint",
          "template": " {{ .FormattedDuration }}{{ if gt .Cost.TotalLinesAdded 0 }} <p:white>·</> <p:green>+{{ .Cost.TotalLinesAdded }}</> <p:red>-{{ .Cost.TotalLinesRemoved }}</>{{ end }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:white",
          "template": "├"
        },
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:green",
          "template": "  {{ .TokenUsagePercent.GaugeUsed }} {{ .TokenUsagePercent }}%<p:grey> ctx</>",
          "foreground_templates": [
            "{{ if ge (.TokenUsagePercent.String | float64) 80.0 }}p:red{{ end }}",
            "{{ if ge (.TokenUsagePercent.String | float64) 50.0 }}p:yellow{{ end }}"
          ]
        },
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:violet",
          "template": "<p:white> · </> {{ if ge .ContextWindow.TotalInputTokens 1000 }}{{ printf \"%.1fk\" (divf .ContextWindow.TotalInputTokens 1000.0) }}{{ else }}{{ .ContextWindow.TotalInputTokens }}{{ end }}↓ {{ if ge .ContextWindow.TotalOutputTokens 1000 }}{{ printf \"%.1fk\" (divf .ContextWindow.TotalOutputTokens 1000.0) }}{{ else }}{{ .ContextWindow.TotalOutputTokens }}{{ end }}↑{{ if gt .ContextWindow.ContextWindowSize 0 }}<p:grey> /{{ printf \"%.0fk\" (divf .ContextWindow.ContextWindowSize 1000.0) }}</>{{ end }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:white",
          "template": "└"
        },
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:green",
          "template": " <p:grey>5h</> {{ .FiveHourUsage.GaugeUsed }} {{ .FiveHourUsage }}%",
          "foreground_templates": [
            "{{ if ge (.FiveHourUsage.String | float64) 80.0 }}p:red{{ end }}",
            "{{ if ge (.FiveHourUsage.String | float64) 50.0 }}p:yellow{{ end }}"
          ]
        },
        {
          "type": "claude",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:green",
          "template": "<p:white> · </><p:grey>7d</> {{ .SevenDayUsage.GaugeUsed }} {{ .SevenDayUsage }}%",
          "foreground_templates": [
            "{{ if ge (.SevenDayUsage.String | float64) 80.0 }}p:red{{ end }}",
            "{{ if ge (.SevenDayUsage.String | float64) 50.0 }}p:yellow{{ end }}"
          ]
        }
      ]
    }
  ],
  "console_title_template": "󰯉 Claude · {{ .Folder }}",
  "final_space": false,
  "version": 4
}
